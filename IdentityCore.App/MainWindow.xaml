<Window x:Class="IdentityCore.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IdentityCore"
        Height="900" 
        Width="1500"
        MinHeight="900"
        MinWidth="1500"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0B0C10">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#14161C"
                BorderBrush="#242731"
                BorderThickness="0,0,1,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="24,0,0,0">
                    <TextBlock Text="🛡"
                               FontSize="24"
                               Foreground="#00D2FF"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="IdentityCore"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                    <RadioButton Content="Panel główny"
                                 Style="{StaticResource SidebarRadioButtonStyle}"
                                 GroupName="MainNavigation"
                                 IsChecked="{Binding IsDashboardActive, Mode=OneWay}"
                                 Command="{Binding ShowDashboardCommand}"/>

                    <RadioButton Content="Rejestr osób"
                                 Style="{StaticResource SidebarRadioButtonStyle}"
                                 GroupName="MainNavigation"
                                 IsChecked="{Binding IsPersonRegistryActive, Mode=OneWay}"
                                 Command="{Binding ShowPersonRegistryCommand}"/>

                    <RadioButton Content="Identyfikacja twarzy"
                                 Style="{StaticResource SidebarRadioButtonStyle}"
                                 GroupName="MainNavigation"
                                 IsChecked="{Binding IsFaceIdentificationActive, Mode=OneWay}"
                                 Command="{Binding ShowFaceIdentificationCommand}"/>

                    <RadioButton Content="Identyfikacja odcisku"
                                 Style="{StaticResource SidebarRadioButtonStyle}"
                                 GroupName="MainNavigation"
                                 IsChecked="{Binding IsFingerprintIdentificationActive, Mode=OneWay}"
                                 Command="{Binding ShowFingerprintIdentificationCommand}"/>

                    <RadioButton Content="Historia prób"
                                 Style="{StaticResource SidebarRadioButtonStyle}"
                                 GroupName="MainNavigation"
                                 IsChecked="{Binding IsHistoryActive, Mode=OneWay}"
                                 Command="{Binding ShowHistoryCommand}"/>

                    <RadioButton Content="Ustawienia"
                                 Style="{StaticResource SidebarRadioButtonStyle}"
                                 GroupName="MainNavigation"
                                 IsChecked="{Binding IsSettingsActive, Mode=OneWay}"
                                 Command="{Binding ShowSettingsCommand}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="16,0,16,16" VerticalAlignment="Bottom">
                    <TextBlock Text="IdentityCore 0.1.0"
                               Foreground="#7E8597"
                               FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1" Background="#0B0C10">
            <Grid.RowDefinitions>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0"
                    Background="#101217"
                    BorderBrush="#242731"
                    BorderThickness="0,0,0,1">

                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   Foreground="White"
                                   FontSize="25"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentPageSubtitle}"
                                   Foreground="#9CA3B4"
                                   FontSize="13"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Wyloguj"
                                Width="104"
                                Height="36"
                                Style="{StaticResource SecondaryButtonStyle}"
                                FontSize="13"
                                Click="LogoutButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"
                            Margin="24"/>
        </Grid>
    </Grid>
</Window>