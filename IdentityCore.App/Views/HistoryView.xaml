<UserControl x:Class="IdentityCore.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#0B0C10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0" Padding="18">
                <StackPanel>
                    <TextBlock Text="Wszystkie próby" Foreground="#9CA3B4" FontSize="13"/>
                    <TextBlock Text="{Binding TotalAttempts}" Foreground="White" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="łączna liczba zdarzeń" Foreground="#7E8597" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0" Padding="18">
                <StackPanel>
                    <TextBlock Text="Znalezione dopasowania" Foreground="#9CA3B4" FontSize="13"/>
                    <TextBlock Text="{Binding FoundAttempts}" Foreground="#00E096" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="próby zakończone identyfikacją" Foreground="#7E8597" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="12,0,0,0" Padding="18">
                <StackPanel>
                    <TextBlock Text="Brak dopasowania" Foreground="#9CA3B4" FontSize="13"/>
                    <TextBlock Text="{Binding NotFoundAttempts}" Foreground="#F87171" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock Text="próby bez osoby w bazie" Foreground="#7E8597" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.25*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,18,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Historia prób identyfikacji"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Rejestr wykonanych prób twarzy i odcisku"
                                       Foreground="#9CA3B4"
                                       FontSize="13"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#F87171"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding BiometricFilterOptions}"
                                  SelectedItem="{Binding SelectedBiometricFilter, Mode=TwoWay}"
                                  Style="{StaticResource InputComboBoxStyle}"
                                  VerticalAlignment="Center"/>

                        <ComboBox Grid.Column="3"
                                  ItemsSource="{Binding DecisionFilterOptions}"
                                  SelectedItem="{Binding SelectedDecisionFilter, Mode=TwoWay}"
                                  Style="{StaticResource InputComboBoxStyle}"
                                  VerticalAlignment="Center"/>

                        <Button Grid.Column="5"
                                Content="Odśwież"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Attempts}"
                              SelectedItem="{Binding SelectedAttempt, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="#17191F"
                              Foreground="White"
                              BorderThickness="0"
                              RowBackground="#17191F"
                              AlternatingRowBackground="#14161C"
                              HorizontalGridLinesBrush="#242731"
                              VerticalGridLinesBrush="#242731"
                              SelectionMode="Single"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#101116"/>
                                <Setter Property="Foreground" Value="#8F96A8"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Height" Value="42"/>
                                <Setter Property="Padding" Value="14,0"/>
                                <Setter Property="BorderBrush" Value="#242731"/>
                                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="54"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#242731"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="14,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Resources>
                            <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data i czas" Binding="{Binding AttemptDate, StringFormat=dd.MM.yyyy HH:mm}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Biometria" Binding="{Binding BiometricTypeDisplay}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Dopasowanie" Binding="{Binding BestMatchDisplay}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Wynik" Binding="{Binding ScoreDisplay}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Decyzja" Binding="{Binding DecisionDisplay}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Plik" Binding="{Binding InputFileName}" Width="*" ElementStyle="{StaticResource GridCellTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Szczegóły próby"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Podgląd wybranego zdarzenia identyfikacji"
                                   Foreground="#9CA3B4"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,18"/>

                        <Border Background="#101116"
                                BorderBrush="#242731"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Wynik"
                                           Foreground="#9CA3B4"
                                           FontSize="13"/>

                                <TextBlock Text="{Binding SelectedAttempt.ScoreDisplay}"
                                           Foreground="#00D2FF"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Margin="0,8,0,0"/>

                                <TextBlock Text="{Binding SelectedAttempt.DecisionDisplay}"
                                           Foreground="#E5E7EB"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Data próby" Style="{StaticResource MutedTextStyle}"/>
                        <Border Background="#101116" BorderBrush="#242731" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,6,0,14">
                            <TextBlock Text="{Binding SelectedAttempt.AttemptDateDisplay}" Foreground="#E5E7EB" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Typ biometrii" Style="{StaticResource MutedTextStyle}"/>
                        <Border Background="#101116" BorderBrush="#242731" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,6,0,14">
                            <TextBlock Text="{Binding SelectedAttempt.BiometricTypeDisplay}" Foreground="#E5E7EB" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Najlepsze dopasowanie" Style="{StaticResource MutedTextStyle}"/>
                        <Border Background="#101116" BorderBrush="#242731" BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,6,0,14">
                            <TextBlock Text="{Binding SelectedAttempt.BestMatchDisplay}" Foreground="#E5E7EB" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <TextBlock Text="Plik wejściowy" Style="{StaticResource MutedTextStyle}"/>
                        <Border Background="#101116" BorderBrush="#242731" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedAttempt.InputFileName}"
                                           Foreground="#E5E7EB"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedAttempt.InputFolder}"
                                           Foreground="#8F96A8"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
