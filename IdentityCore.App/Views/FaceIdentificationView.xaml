<UserControl x:Class="IdentityCore.App.Views.FaceIdentificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#0B0C10">
        <Grid.Resources>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>

            <Style x:Key="SmallLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#8F96A8"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>
        </Grid.Resources>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ŹRÓDŁO BIOMETRYCZNE -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,14,0"
                    MinHeight="720">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="▣  Źródło biometryczne"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Border Grid.Row="2"
                            Background="#08090D"
                            BorderBrush="#303440"
                            BorderThickness="1"
                            CornerRadius="10"
                            MinHeight="365"
                            ClipToBounds="True">

                        <Grid>
                            <Grid.Background>
                                <DrawingBrush TileMode="Tile"
                                              Viewport="0,0,24,24"
                                              ViewportUnits="Absolute"
                                              Opacity="0.16">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Brush="Transparent">
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#3A3F4B" Thickness="1"/>
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="24,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,24"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Grid.Background>

                            <Rectangle Stroke="#2E3340"
                                       StrokeThickness="1"
                                       StrokeDashArray="4 4"
                                       RadiusX="10"
                                       RadiusY="10"
                                       Margin="12"/>

                            <Image Source="{Binding PreviewImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="14"/>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding PreviewOverlayVisibility}">
                                <TextBlock Text="⌗"
                                           Foreground="#3E4454"
                                           FontSize="54"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="{Binding CameraPreviewStatus}"
                                           Foreground="#7E8597"
                                           FontSize="14"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Uruchom kamerę"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding StartCameraCommand}"/>

                        <Button Grid.Column="2"
                                Content="Wyłącz kamerę"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding StopCameraCommand}"/>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Zrób zdjęcie"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CapturePhotoCommand}"/>

                        <Button Grid.Column="2"
                                Content="Wczytaj obraz"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding LoadImageCommand}"/>
                    </Grid>

                    <Border Grid.Row="7"
                            Background="#101116"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,16,0,0">
                        <TextBlock Text="Obsługiwane źródła: kamera internetowa oraz pliki JPG/PNG"
                                   Foreground="#7E8597"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ANALIZA BIOMETRYCZNA -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}"
                    Margin="14,0,14,0"
                    MinHeight="720">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="▣  Analiza biometryczna"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="132"
                                Height="132"
                                Background="#0A0B10"
                                BorderBrush="#39475A"
                                BorderThickness="2"
                                CornerRadius="8"
                                ClipToBounds="True"
                                HorizontalAlignment="Left">
                            <Grid>
                                <Image Source="{Binding AnalysisCropImage}"
                                       Stretch="UniformToFill"
                                       Width="132"
                                       Height="132"
                                       Visibility="{Binding AnalysisCropImageVisibility}"/>

                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding AnalysisCropPlaceholderVisibility}">
                                    <TextBlock Text="□"
                                               Foreground="#3E4454"
                                               FontSize="34"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="crop twarzy"
                                               Foreground="#7E8597"
                                               FontSize="12"
                                               Margin="0,6,0,0"/>
                                </StackPanel>

                                <Border Height="3"
                                        Background="#00D2FF"
                                        Opacity="0.95"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding ScanAnimationVisibility}">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="-70"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.8" Color="#00D2FF"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="Visibility" Value="Visible">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                 From="-70"
                                                                                 To="132"
                                                                                 Duration="0:0:1.2"
                                                                                 RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1" Margin="18,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Model:" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="ML.NET / ArcFace ONNX" Foreground="White" FontSize="13"/>

                            <TextBlock Grid.Row="1" Text="Jakość próbki:" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SampleQualityText}" Foreground="#00E096" FontWeight="SemiBold" FontSize="13"/>

                            <TextBlock Grid.Row="2" Text="Źródło:" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="kamera / plik" Foreground="#C8CDD8" FontSize="13"/>

                            <TextBlock Grid.Row="3" Text="Baza:" Style="{StaticResource MutedTextStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="szablony twarzy" Foreground="#C8CDD8" FontSize="13"/>
                        </Grid>
                    </Grid>

                    <ItemsControl Grid.Row="4" ItemsSource="{Binding AnalysisSteps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,13">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Icon}"
                                               Foreground="{Binding Brush}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Status}"
                                               Foreground="{Binding Brush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="6">
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Postęp analizy" Foreground="#9CA3B4" FontSize="12"/>
                            <TextBlock Text="{Binding AnalysisProgressText}" Foreground="#C8CDD8" FontSize="12" HorizontalAlignment="Right"/>
                        </Grid>

                        <ProgressBar Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding AnalysisProgress}"
                                     Foreground="#0EA5C6"
                                     Background="#303440"/>

                        <Button Content="▶  Rozpocznij identyfikację"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding StartIdentificationCommand}"
                                Margin="0,22,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WYNIK IDENTYFIKACJI -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Margin="14,0,0,0"
                    MinHeight="720">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="♙  Wynik identyfikacji"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="122"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="112"
                                Height="140"
                                Background="#08090D"
                                BorderBrush="#2A2E3A"
                                BorderThickness="1"
                                CornerRadius="8"
                                HorizontalAlignment="Left"
                                ClipToBounds="True">
                            <Grid>
                                <Image Source="{Binding MatchedProfileImagePath}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding ProfileImageVisibility}"/>

                                <StackPanel VerticalAlignment="Center"
                                            Visibility="{Binding ProfilePlaceholderVisibility}"
                                            Margin="8">
                                    <TextBlock Text="Brak"
                                               Foreground="#9CA3B4"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="profilówki"
                                               Foreground="#9CA3B4"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="16,4,0,0">
                            <TextBlock Text="{Binding BestMatchName}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="20"
                                       TextWrapping="Wrap"/>

                            <Border Background="#1F2937"
                                    BorderBrush="#374151"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="8,4"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,16">
                                <TextBlock Text="{Binding BestMatchStatus}"
                                           Foreground="#A7F3D0"
                                           FontSize="12"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="ID osoby:" Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BestMatchCode}" Foreground="White" FontSize="13"/>

                                <TextBlock Grid.Row="1" Text="Dział:" Style="{StaticResource MutedTextStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BestMatchDepartment}" Foreground="White" FontSize="13"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="4"
                            Background="#08090D"
                            BorderBrush="#242731"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Wynik podobieństwa" Foreground="#7E8597" FontSize="12"/>
                                <TextBlock Text="{Binding SimilarityScoreText}" Foreground="#00D2FF" FontSize="34" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding MarginScoreText}" Foreground="#9CA3B4" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Decyzja systemu" Foreground="#7E8597" FontSize="12" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding Decision}" Foreground="#00E096" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SecondBestScoreText}" Foreground="#9CA3B4" FontSize="11" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="6"
                            Background="#08090D"
                            BorderBrush="#242731"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="12">

                        <StackPanel>
                            <TextBlock Text="Najbliższe dopasowania"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding TopCandidates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="76"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Rank}"
                                                       Foreground="#00D2FF"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding PersonFullName}"
                                                           Foreground="#E5E7EB"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Text="{Binding DecisionHint}"
                                                           Foreground="#8F96A8"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SimilarityScoreText}"
                                                       Foreground="#00E096"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="7" Margin="0,18,0,0">
                        <Button Content="Otwórz profil osoby"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenPersonProfileCommand}"
                                IsEnabled="{Binding IsOpenProfileEnabled}"
                                Margin="0,0,0,10"/>

                        <Button Content="Zapisz próbę"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SaveAttemptCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- TOAST / POPUP KOMUNIKATÓW -->
        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,22,22,0"
                Width="520"
                Background="{Binding ToastBackground}"
                BorderBrush="{Binding ToastAccentBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Visibility="{Binding ToastVisibility}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="24"
                        Height="24"
                        Background="{Binding ToastAccentBrush}"
                        CornerRadius="12"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding ToastIcon}"
                               Foreground="#0B0C10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding ToastMessage}"
                           Foreground="White"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
