<UserControl x:Class="IdentityCore.App.Views.PersonRegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Grid Background="#0B0C10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- KAFELKI STATYSTYK -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="18,14">
                <StackPanel>
                    <TextBlock Text="Osoby w bazie" Foreground="#9CA3B4" FontSize="12"/>
                    <TextBlock Text="{Binding TotalPersons}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="Wszystkie rekordy osobowe" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0" Padding="18,14">
                <StackPanel>
                    <TextBlock Text="Osoby z biometrią" Foreground="#9CA3B4" FontSize="12"/>
                    <TextBlock Text="{Binding PersonsWithBiometrics}" Foreground="#00E096" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="Mają twarz lub odcisk" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0" Padding="18,14">
                <StackPanel>
                    <TextBlock Text="Próbki twarzy" Foreground="#9CA3B4" FontSize="12"/>
                    <TextBlock Text="{Binding TotalFaceTemplates}" Foreground="#00D2FF" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="Szablony do identyfikacji" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="18,14">
                <StackPanel>
                    <TextBlock Text="Próbki odcisków" Foreground="#9CA3B4" FontSize="12"/>
                    <TextBlock Text="{Binding TotalFingerprintTemplates}" Foreground="#FBBF24" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    <TextBlock Text="Szablony do identyfikacji" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GŁÓWNY UKŁAD -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- LISTA OSÓB -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    VerticalAlignment="Stretch">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Rejestr osób"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Lista osób zapisanych w systemie identyfikacji"
                                       Foreground="#8F96A8"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="+ Dodaj osobę"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38"
                                VerticalAlignment="Center"
                                Command="{Binding AddNewPersonCommand}"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Persons}"
                              SelectedItem="{Binding SelectedListPerson, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="#15171D"
                              Foreground="White"
                              BorderThickness="0"
                              RowBackground="#15171D"
                              AlternatingRowBackground="#12141A"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Margin="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="DataGrid_SelectionChanged">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#0F1117"/>
                                <Setter Property="Foreground" Value="#8F96A8"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Height" Value="38"/>
                                <Setter Property="Padding" Value="12"/>
                                <Setter Property="BorderBrush" Value="#242731"/>
                                <Setter Property="BorderThickness" Value="0,1,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="48"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#242731"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#112934"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1B2029"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E5E7EB"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Resources>
                            <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID osoby"
                                                Binding="{Binding PersonCode}"
                                                Width="*"
                                                ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Imię i nazwisko"
                                                Binding="{Binding FullName}"
                                                Width="*"
                                                ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Dział / jednostka"
                                                Binding="{Binding Department}"
                                                Width="*"
                                                ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTextColumn Header="Data dodania"
                                                Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                                Width="*"
                                                ElementStyle="{StaticResource GridCellTextStyle}"/>
                            <DataGridTemplateColumn Header="" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Otwórz"
                                                Height="30"
                                                MinWidth="86"
                                                Padding="10,0"
                                                Margin="12,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.OpenPersonDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- SZCZEGÓŁY OSOBY -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    MinWidth="600">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="18,16,18,10">
                        <TextBlock Text="Profil osoby"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Dane osobowe, profilówka i próbki biometryczne"
                                   Foreground="#9CA3B4"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="18,0,18,0"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                            <!-- ZDJĘCIE PROFILOWE -->
                            <Border Background="#101116"
                                    BorderBrush="#242731"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="112"
                                            Height="112"
                                            Background="#08090D"
                                            BorderBrush="#2A2E39"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="Zdjęcie&#x0a;profilowe"
                                                       Foreground="#4B5563"
                                                       FontSize="12"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Image Source="{Binding SelectedProfilePreviewImage}"
                                                   Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedPerson.FullName}"
                                                   Foreground="White"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedPerson.PersonCode}"
                                                   Foreground="#00D2FF"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,3,0,8"/>

                                        <TextBlock Text="Zdjęcie wyświetlane po pozytywnym dopasowaniu twarzy lub odcisku."
                                                   Foreground="#8F96A8"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="Ustaw zdjęcie"
                                                    Height="38"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Command="{Binding SetProfileImageCommand}"/>

                                            <Button Grid.Column="2"
                                                    Content="Usuń zdjęcie"
                                                    Height="38"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding RemoveProfileImageCommand}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- SZABLONY BIOMETRYCZNE -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#101116"
                                        BorderBrush="#242731"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Twarz"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>

                                        <Border Width="92"
                                                Height="92"
                                                Background="#08090D"
                                                BorderBrush="#2A2E39"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                ClipToBounds="True"
                                                HorizontalAlignment="Center">
                                            <Grid>
                                                <TextBlock Text="brak&#x0a;próbki"
                                                           Foreground="#4B5563"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <Image Source="{Binding SelectedFacePreviewImage}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding SelectedPersonFaceTemplatesCount, StringFormat=Szablony: {0}}"
                                                   Foreground="#00D2FF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,8"/>

                                        <Button Content="Zarejestruj twarz"
                                                Height="38"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding RegisterFaceSampleCommand}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#101116"
                                        BorderBrush="#242731"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Odcisk palca"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>

                                        <Border Width="92"
                                                Height="92"
                                                Background="#08090D"
                                                BorderBrush="#2A2E39"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                ClipToBounds="True"
                                                HorizontalAlignment="Center">
                                            <Grid>
                                                <TextBlock Text="brak&#x0a;próbki"
                                                           Foreground="#4B5563"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <Image Source="{Binding SelectedFingerprintPreviewImage}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding SelectedPersonFingerprintTemplatesCount, StringFormat=Szablony: {0}}"
                                                   Foreground="#FBBF24"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,8"/>

                                        <Button Content="Zarejestruj odcisk"
                                                Height="38"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding RegisterFingerprintSampleCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- DANE OSOBY -->
                            <TextBlock Text="ID osoby" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding SelectedPerson.PersonCode}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     IsReadOnly="True"
                                     Margin="0,5,0,10"/>

                            <TextBlock Text="Imię" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding SelectedPerson.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,5,0,10"/>

                            <TextBlock Text="Nazwisko" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding SelectedPerson.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,5,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Data urodzenia" Style="{StaticResource MutedTextStyle}"/>
                                    <DatePicker SelectedDate="{Binding SelectedPerson.DateOfBirth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource InputDatePickerStyle}"
                                                Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Płeć" Style="{StaticResource MutedTextStyle}"/>
                                    <ComboBox SelectedItem="{Binding SelectedPerson.Gender, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource InputComboBoxStyle}"
                                              Margin="0,5,0,0" SelectionChanged="ComboBox_SelectionChanged">
                                        <sys:String>Nie podano</sys:String>
                                        <sys:String>Kobieta</sys:String>
                                        <sys:String>Mężczyzna</sys:String>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Dział / jednostka" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding SelectedPerson.Department, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,5,0,10"/>

                            <TextBlock Text="Opis" Style="{StaticResource MutedTextStyle}"/>
                            <TextBox Text="{Binding SelectedPerson.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     MinHeight="82"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalContentAlignment="Top"
                                     Margin="0,5,0,10"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="18,12,18,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Zapisz zmiany"
                                Height="40"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveChangesCommand}"/>

                        <Button Grid.Column="2"
                                Content="Usuń osobę"
                                Height="40"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DeleteSelectedPersonCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
