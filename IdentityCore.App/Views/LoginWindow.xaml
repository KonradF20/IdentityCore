<Window x:Class="IdentityCore.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IdentityCore - Logowanie"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B0C10">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <!-- LEWY PANEL -->
        <Border Grid.Column="0"
                Background="#101217"
                BorderBrush="#242731"
                BorderThickness="0,0,1,0">

            <Grid Margin="54">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="🛡"
                               FontSize="42"
                               Foreground="#00D2FF">
                    </TextBlock>

                    <TextBlock Text="IdentityCore"
                               Foreground="White"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,18,0,0"/>

                    <TextBlock Text="Wewnętrzny system identyfikacji osób"
                               Foreground="#9CA3B4"
                               FontSize="16"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="System demonstracyjny do identyfikacji osób na podstawie danych biometrycznych twarzy oraz odcisku palca."
                               Foreground="#C8CDD8"
                               FontSize="18"
                               TextWrapping="Wrap"
                               LineHeight="28"/>

                    <Border Background="#17191F"
                            BorderBrush="#2A2E39"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18"
                            Margin="0,34,0,0">

                        <StackPanel>
                            <TextBlock Text="Zakres modułów"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"/>

                            <TextBlock Text="• Rejestr osób i próbki biometryczne"
                                       Foreground="#9CA3B4"
                                       FontSize="14"
                                       Margin="0,14,0,0"/>

                            <TextBlock Text="• Identyfikacja twarzy z obrazu lub kamery"
                                       Foreground="#9CA3B4"
                                       FontSize="14"
                                       Margin="0,8,0,0"/>

                            <TextBlock Text="• Identyfikacja odcisku palca z pliku"
                                       Foreground="#9CA3B4"
                                       FontSize="14"
                                       Margin="0,8,0,0"/>

                            <TextBlock Text="• Historia prób identyfikacji"
                                       Foreground="#9CA3B4"
                                       FontSize="14"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Projekt C# / WPF / SQL Server"
                           Foreground="#7E8597"
                           FontSize="13"/>
            </Grid>
        </Border>

        <!-- PRAWY PANEL LOGOWANIA -->
        <Grid Grid.Column="1">
            <Border Width="380"
                    Background="#17191F"
                    BorderBrush="#2A2E39"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock Text="Logowanie operatora"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="Podaj dane dostępowe do systemu"
                               Foreground="#9CA3B4"
                               FontSize="13"
                               Margin="0,6,0,26"/>

                    <TextBlock Text="Login"
                               Foreground="#9CA3B4"
                               FontSize="13"/>

                    <TextBox x:Name="UsernameTextBox"
                             Text="admin"
                             Style="{StaticResource InputTextBoxStyle}"
                             Height="42"
                             FontSize="14"
                             Margin="0,6,0,18"/>

                    <TextBlock Text="Hasło"
                               Foreground="#9CA3B4"
                               FontSize="13"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Password="admin"
                                 Style="{StaticResource InputPasswordBoxStyle}"
                                 Height="42"
                                 FontSize="14"
                                 Margin="0,6,0,12"/>

                    <TextBlock x:Name="ErrorTextBlock"
                               Foreground="#F87171"
                               FontSize="12"
                               TextWrapping="Wrap"
                               MinHeight="18"
                               Margin="0,0,0,14"/>

                    <Button Content="Zaloguj"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="44"
                            IsDefault="True"
                            Click="LoginButton_Click"/>

                    <Border Background="#101116"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,22,0,0">

                        <TextBlock Text="Konto testowe: admin / admin"
                                   Foreground="#7E8597"
                                   FontSize="12"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
