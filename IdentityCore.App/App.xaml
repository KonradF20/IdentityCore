<Application x:Class="IdentityCore.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:IdentityCore.App.Views"
             xmlns:viewModels="clr-namespace:IdentityCore.App.ViewModels"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Styles/Cards.xaml"/>
                <ResourceDictionary Source="Styles/DataGrid.xaml"/>
                <ResourceDictionary Source="Styles/Inputs.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:PersonRegistryViewModel}">
                <views:PersonRegistryView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:FaceIdentificationViewModel}">
                <views:FaceIdentificationView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:FingerprintIdentificationViewModel}">
                <views:FingerprintIdentificationView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:HistoryViewModel}">
                <views:HistoryView />
            </DataTemplate>


            <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>

        </ResourceDictionary>

    </Application.Resources>
</Application>